# ---------------------------------------------------------
# 2. CHECKING FOR OUTLIERS (MAHALANOBIS)
# ---------------------------------------------------------

data <- read.csv("data/merged_data.csv", sep = ",", quote = "", header = TRUE)

# Keep only numeric columns 
num_data <- data[, sapply(data, is.numeric), drop = FALSE]

# Remove one dummy per dummy set 
x <- subset(
  num_data,
  select = -c(
    X..geom_household_age1....25.years..,
    X..geom_clothing_budget2..Below.average..
  )
)

# Calculate variance matrix 
Sx <- cov(x)

# Calculate Mahalanobis distance 
D2 <- mahalanobis(x, colMeans(x), Sx)

# Plot Chi-square distribution with df = 24
cutoff <- qchisq(0.999, df = ncol(x))

# Identify outlier rows
outlier_rows <- which(D2 > cutoff)
normal_rows <- which(D2 <= cutoff)

# Compare means of variables
outlier_means <- colMeans(x[outlier_rows, ])
normal_means <- colMeans(x[normal_rows, ])

comparison <- data.frame(
  Variable = names(x),
  Outlier_mean = outlier_means,
  Normal_mean = normal_means,
  Difference = abs(outlier_means - normal_means)
)
comparison_sorted <- comparison[order(-comparison$Difference), ]

print(paste("Rows in original data:", nrow(data)))
print(paste("Number of outliers identified:", length(outlier_rows)))
print(paste("Percentage of data as outliers:", round(length(outlier_rows)/nrow(x)*100, 2), "%"))

# ---------------------------------------------------------
# 3. IMPUTING MISSING DATA WITH MICE
# ---------------------------------------------------------

ecommerce_data <- read_csv("data/merged_data.csv")

# Convert missing values to NA
ecommerce_data[] <- lapply(ecommerce_data, function(x) {
  if (is.character(x)) {
    x[x %in% c("NULL", "Unknown", "unknown", "")] <- NA
  }
  x
})

# Convert variables to correct type
ecommerce_data$internet_session_id  <- as.character(ecommerce_data$internet_session_id)
ecommerce_data$customer_id          <- as.character(ecommerce_data$customer_id)
ecommerce_data$session_date         <- as.Date(ecommerce_data$session_date)

ecommerce_data$device_category_desc <- as.factor(ecommerce_data$device_category_desc)
ecommerce_data$geom_household_age   <- as.factor(ecommerce_data$geom_household_age)
ecommerce_data$geom_clothing_budget <- as.factor(ecommerce_data$geom_clothing_budget)
ecommerce_data$geom_reads_newspaper <- as.factor(ecommerce_data$geom_reads_newspaper)
ecommerce_data$focal_brand_share    <- as.numeric(ecommerce_data$focal_brand_share)

final_data <- ecommerce_data

imp_data <- ecommerce_data[, c(
  "focal_brand_share",
  "device_category_desc",
  "geom_household_age",
  "geom_clothing_budget",
  "geom_reads_newspaper"
)]

imp_data$device_category_desc <- droplevels(imp_data$device_category_desc)
imp_data$geom_household_age   <- droplevels(imp_data$geom_household_age)
imp_data$geom_clothing_budget <- droplevels(imp_data$geom_clothing_budget)
imp_data$geom_reads_newspaper <- droplevels(imp_data$geom_reads_newspaper)

# Initialize MICE
ini <- mice(imp_data, maxit = 0, printFlag = FALSE)
meth <- ini$method
pred <- ini$predictorMatrix

meth["focal_brand_share"]    <- "pmm"
meth["device_category_desc"] <- "polyreg"
meth["geom_household_age"]   <- "polyreg"
meth["geom_clothing_budget"] <- "polyreg"

n_levels_newspaper <- nlevels(droplevels(imp_data$geom_reads_newspaper))
if (n_levels_newspaper == 2) {
  meth["geom_reads_newspaper"] <- "logreg"
} else {
  meth["geom_reads_newspaper"] <- "polyreg"
}

# Run MICE
imp <- mice(imp_data, method = meth, predictorMatrix = pred, m = 1, maxit = 5, seed = 123, printFlag = FALSE)
completed_part <- complete(imp, 1)

final_data$focal_brand_share    <- completed_part$focal_brand_share
final_data$device_category_desc <- completed_part$device_category_desc
final_data$geom_household_age   <- completed_part$geom_household_age
final_data$geom_clothing_budget <- completed_part$geom_clothing_budget
final_data$geom_reads_newspaper <- completed_part$geom_reads_newspaper

write_csv(final_data, "data/merged_data_imputed.csv")


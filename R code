# ==============================================================================
# FINAL MULTIVARIABLE MODEL & COLLINEARITY CHECK
# ==============================================================================

final_model_data <- final_data %>%
  mutate(
    converted = as.numeric(as.character(converted)),
    is_weekend = as.factor(as.character(is_weekend)),
    device_category_desc = as.factor(as.character(device_category_desc)),
    geom_household_age = as.factor(as.character(geom_household_age)),
    geom_clothing_budget = as.factor(as.character(geom_clothing_budget)),
    geom_reads_newspaper = as.factor(as.character(geom_reads_newspaper)),
    session_brand_weight = as.numeric(session_brand_weight),
    SQ = as.numeric(SQ),
    TX = as.numeric(TX),
    DR = as.numeric(DR),
    num_distinct_class_3 = as.numeric(num_distinct_class_3),
    focal_brand_share = as.numeric(focal_brand_share)
  )

# Final logistic regression
final_model <- glm(
  converted ~ session_brand_weight +
    num_distinct_class_3 +
    device_category_desc +
    is_weekend +
    SQ + TX + DR +
    focal_brand_share +
    geom_household_age +
    geom_clothing_budget +
    geom_reads_newspaper,
  data = final_model_data,
  family = binomial,
  na.action = na.exclude
)

summary(final_model)

# Collinearity Check (VIF)
v <- vif(final_model)
if (is.matrix(v)) {
  adjusted_vif <- v[, "GVIF"]^(1 / (2 * v[, "Df"]))
  vif_table <- data.frame(
    Variable = rownames(v),
    GVIF = v[, "GVIF"],
    Df = v[, "Df"],
    Adjusted_VIF = adjusted_vif
  )
  print(vif_table)
} else {
  vif_table <- data.frame(Variable = names(v), VIF = as.numeric(v))
  print(vif_table)
}

# Clean Regression Table
model_table <- tidy(final_model) %>%
  mutate(
    odds_ratio = exp(estimate),
    p.value = round(p.value, 4)
  )

